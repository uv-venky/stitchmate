{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/components/core/*": [
        "./node_modules/uv-core/dist/components/core/*"
      ],
      "@/components/ui/*": [
        "./node_modules/uv-core/dist/components/ui/*"
      ],
      "@/components/sidebar/*": [
        "./node_modules/uv-core/dist/components/sidebar/*"
      ],
      "@/components/*": [
        "./src/components/*",
        "./node_modules/uv-core/dist/components/*"
      ],
      "@/hooks/*": [
        "./src/hooks/*",
        "./node_modules/uv-core/dist/hooks/*"
      ],
      "@/app/*": [
        "./src/app/*",
        "./node_modules/uv-core/dist/app/*"
      ],
      "@/plugins/*": [
        "./src/plugins/*",
        "./node_modules/uv-core/dist/plugins/*"
      ],
      "@/lib/common/*": [
        "./node_modules/uv-core/dist/lib/common/*"
      ],
      "@/lib/*": [
        "./node_modules/uv-core/dist/lib/*",
        "./src/lib/*"
      ],
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules"
  ]
}
