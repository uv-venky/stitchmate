    "migration:create": "node node_modules/uv-core/dist/lib/cli/create-migration.js"
  },
  "dependencies": {
    "dotenv": "17.4.2",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "uv-core": "link:../uv-core"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "tsx": "4.22.3",
    "typescript": "6.0.3"
  }
}