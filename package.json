{
  "name": "stitchmate",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc --noEmit",
    "migrate": "tsx node_modules/uv-core/scripts/migrate.ts",
    "rollback": "tsx node_modules/uv-core/scripts/rollback.ts",
    "migration:create": "tsx node_modules/uv-core/scripts/create-migration.ts"
  },
  "dependencies": {
    "dotenv": "17.4.2",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "uv-core": "github:uv-venky/uv-core#v1.0.2"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "tsx": "4.22.3",
    "typescript": "6.0.3"
  }
}
